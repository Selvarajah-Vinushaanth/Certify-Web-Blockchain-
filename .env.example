# Blockchain – Sepolia via Infura
# 1. Create a free account at https://www.infura.io/
# 2. Create a new project and copy the Sepolia endpoint
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Your wallet private key (the account that will deploy & own the contract)
# Export from MetaMask: Account details → Export private key
# ⚠️ NEVER commit this file with real keys!
PRIVATE_KEY=your_wallet_private_key_here